generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum PermissionEffect {
  GRANT
  DENY
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles               UserRole[]
  permissionOverrides UserPermission[]
  tasks               Task[]
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]
}

// Fixed, code-defined catalog, seeded read-only — not admin-creatable via API. Stored here
// only so RolePermission/UserPermission can reference a permission by FK.
model Permission {
  id  String @id @default(uuid())
  key String @unique

  roles         RolePermission[]
  userOverrides UserPermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// getPermissionSources looks up both of these tables by userId alone, with no explicit
// @@index([userId]) — not an oversight. Postgres can use a multi-column btree index for an
// equality lookup on just its leading column, and userId is the leading column of both the
// @@id below and UserPermission's @@unique, so those constraints double as the userId index.
model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model UserPermission {
  id           String           @id @default(uuid())
  userId       String
  permissionId String
  effect       PermissionEffect

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model Task {
  id          String     @id @default(uuid())
  // Mirrors the DTO's Zod limits (docs/FEATURES_AND_API.md) at the column level too — Zod only
  // guards the API surface, and a direct DB write (a script, a future admin tool, a migration
  // bug) would otherwise accept an arbitrarily long value with no schema-level backstop.
  title       String     @db.VarChar(200)
  description String?    @db.VarChar(2000)
  status      TaskStatus @default(TODO)
  dueDate     DateTime
  ownerId     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  // Soft delete: DELETE /tasks/:id sets this instead of removing the row. Null means "not
  // deleted" — every repository query filters on it, and the API response never includes this
  // column (see the repository's explicit `select`), so a soft-deleted task is indistinguishable
  // from a hard-deleted one to any API caller.
  deletedAt   DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Every list query sorts by createdAt DESC and optionally filters by ownerId and/or status —
  // these match the three real query shapes (owner-scoped, status-scoped, unfiltered) rather
  // than indexing each column independently.
  @@index([ownerId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}
