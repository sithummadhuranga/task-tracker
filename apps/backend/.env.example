NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/task_tracker
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173

# Generate a 48-byte base64 string for your secret (e.g., using: openssl rand -base64 48).
# The value below is just an example of the expected format.
JWT_ACCESS_SECRET=00wTtlkOzxkxyIBqASd3wH2kEMhZT1m0Grio3Py26vn870uWAlHhGxXlI+Cb1A5G

# Example credentials for the initial admin account seeding.
# Be sure to set a strong password for your actual deployment.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123

# Attempts allowed per IP, per window, on /auth/login and /auth/register.
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# One of fatal|error|warn|info|debug|trace|silent. "silent" is used by the test suite to keep
# request-log noise out of CI output.
LOG_LEVEL=info
