POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=task_tracker
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=4000
FRONTEND_PORT=5173
CORS_ORIGIN=http://localhost:5173
# Baked into the frontend's static JS bundle at `docker compose build` time (Vite has no
# server process at runtime to read this later) — only needs to change if BACKEND_PORT does.
VITE_API_URL=http://localhost:4000
# Generate your own with: openssl rand -base64 48
JWT_ACCESS_SECRET=00wTtlkOzxkxyIBqASd3wH2kEMhZT1m0Grio3Py26vn870uWAlHhGxXlI+Cb1A5G
# Identity for the one seeded admin account. Both are only read the first time that account
# is created in a given database — changing them afterward does nothing, by design.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123
