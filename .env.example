POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=task_tracker
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=4000
FRONTEND_PORT=5173
CORS_ORIGIN=http://localhost:5173
# Baked into the frontend's static JS bundle at docker compose build time (Vite has no
# server process at runtime to read this later) — only needs to change if BACKEND_PORT does.
VITE_API_URL=http://localhost:4000

# Generate a 48-byte base64 string for your secret (e.g., using: openssl rand -base64 48).
# The value below is just an example of the expected format.
JWT_ACCESS_SECRET=00wTtlkOzxkxyIBqASd3wH2kEMhZT1m0Grio3Py26vn870uWAlHhGxXlI+Cb1A5G

# Example credentials for the initial admin account seeding.
# Be sure to set a strong password for your actual deployment.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123

AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Optional — enables the "Magic Polish" AI task-formatting endpoint (POST /tasks/magic-polish).
# Get a free-tier key at https://aistudio.google.com/apikey. Leave blank to run without it: the
# app still boots normally, and that one endpoint responds 503 instead of failing to start.
GEMINI_API_KEY=
